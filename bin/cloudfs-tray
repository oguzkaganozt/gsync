#!/usr/bin/env python3
"""
cloudfs-tray: system tray indicator for cloudfs.

Cloud icon states:
  Grey         -> idle (watching, last sync OK)
  Bright+arrow -> syncing right now
  Amber "!"    -> last sync had errors
  Slashed      -> paused (service stopped)

Left-click: sync now. Right-click: menu (sync, add folder, pause/resume,
servers, log, quit). Autostarted via systemd user service (cloudfs-tray.service).
Requires PyGObject + GTK3 + libayatana-appindicator (Gtk.StatusIcon fallback).
"""
import io
import os
import shutil
import subprocess
import sys
import tempfile
import threading
import time

import cairo
import gi

gi.require_version("Gtk", "3.0")
from gi.repository import GLib, Gtk, Gdk, GdkPixbuf  # noqa: E402

try:
    gi.require_version("AyatanaAppIndicator3", "0.1")
    from gi.repository import AyatanaAppIndicator3 as AppIndicator  # noqa: E402

    HAS_AYATANA = True
except (ValueError, ImportError):
    HAS_AYATANA = False

SERVICE = "cloudfs.service"
# Absolute path: under systemd --user, PATH does not include ~/.local/bin.
CLOUDFS_BIN = os.path.expanduser("~/.local/bin/cloudfs")
STATUS_FILE = os.path.expanduser("~/.local/state/cloudfs/status")
POLL_SEC = 3
ICON_SIZE = 24

STATES = ("idle", "syncing", "error", "paused")


def _service_active() -> bool:
    r = subprocess.run(
        ["systemctl", "--user", "is-active", SERVICE],
        capture_output=True, text=True, timeout=5.0,
    )
    return r.stdout.strip() == "active"


def _unit_state(unit: str) -> str:
    try:
        r = subprocess.run(
            [
                "systemctl", "--user", "show", unit,
                "--property=ActiveState", "--property=SubState",
                "--property=Result",
            ],
            capture_output=True, text=True, timeout=2.0,
        )
        if r.returncode != 0:
            return "unmounted"
        values = {}
        for line in r.stdout.splitlines():
            key, separator, value = line.partition("=")
            if separator:
                values[key] = value
        active = values.get("ActiveState", "")
        sub = values.get("SubState", "")
        result = values.get("Result", "")
        if active == "active":
            return "mounted"
        if active == "activating" or sub == "auto-restart":
            return "retrying"
        if active == "inactive":
            return "unmounted"
        if active == "failed" or (result and result != "success"):
            return "failed"
        return "unmounted"
    except Exception:
        return "unknown"


def _read_status():
    """Returns (state, epoch) from the daemon's status file."""
    try:
        with open(STATUS_FILE) as f:
            state, ts = f.read().strip().split("|", 1)
        return state, int(ts)
    except Exception:
        return "idle", 0


def _current_state(
    servers: list, drive_state: str, service_active: bool, sync_status: tuple
) -> tuple:
    if drive_state in ("failed", "retrying") or any(
        state in ("failed", "retrying") for _alias, state, _path in servers
    ):
        return "error", 0
    if not service_active:
        return "paused", 0
    state, ts = sync_status
    if state not in ("syncing", "error"):
        state = "idle"
    return state, ts


def _draw_cloud(cr, color):
    cr.set_source_rgb(*color)
    cr.set_line_width(2.0)
    cr.set_line_cap(cairo.LINE_CAP_ROUND)
    cr.set_line_join(cairo.LINE_JOIN_ROUND)
    cr.move_to(6.5, 16.5)
    cr.curve_to(3.0, 16.5, 2.6, 11.8, 6.2, 11.2)
    cr.curve_to(6.6, 8.0, 10.8, 6.8, 13.0, 9.0)
    cr.curve_to(16.8, 7.4, 20.2, 10.2, 19.0, 13.2)
    cr.curve_to(21.4, 13.8, 21.2, 16.5, 18.0, 16.5)
    cr.close_path()
    cr.stroke()


def _render_surface(state: str) -> cairo.ImageSurface:
    s = cairo.ImageSurface(cairo.FORMAT_ARGB32, ICON_SIZE, ICON_SIZE)
    cr = cairo.Context(s)
    cr.set_operator(cairo.OPERATOR_CLEAR)
    cr.paint()
    cr.set_operator(cairo.OPERATOR_OVER)
    cr.scale(ICON_SIZE / 24, ICON_SIZE / 24)

    grey = (0.62, 0.62, 0.62)
    bright = (0.95, 0.95, 0.95)
    amber = (0.95, 0.72, 0.25)
    dark = (0.45, 0.45, 0.45)

    if state == "syncing":
        _draw_cloud(cr, bright)
        cr.set_source_rgb(*bright)
        cr.set_line_width(1.8)
        cr.move_to(12, 15.2)
        cr.line_to(12, 11.2)
        cr.stroke()
        cr.move_to(10.2, 12.8)
        cr.line_to(12, 11.0)
        cr.line_to(13.8, 12.8)
        cr.stroke()
    elif state == "error":
        _draw_cloud(cr, amber)
        cr.set_source_rgb(*amber)
        cr.set_line_width(1.9)
        cr.move_to(12, 10.6)
        cr.line_to(12, 13.4)
        cr.stroke()
        cr.arc(12, 15.4, 0.55, 0, 6.3)
        cr.fill()
    elif state == "paused":
        _draw_cloud(cr, dark)
        cr.set_source_rgb(*dark)
        cr.set_line_width(1.8)
        cr.move_to(6.0, 19.0)
        cr.line_to(19.0, 6.0)
        cr.stroke()
    else:  # idle
        _draw_cloud(cr, grey)

    return s


def _render_pixbuf(state: str) -> GdkPixbuf.Pixbuf:
    return Gdk.pixbuf_get_from_surface(
        _render_surface(state), 0, 0, ICON_SIZE, ICON_SIZE
    )


def _render_png(state: str) -> bytes:
    s = _render_surface(state)
    buf = io.BytesIO()
    s.write_to_png(buf)
    return buf.getvalue()


def _cloudfs_list() -> list:
    try:
        r = subprocess.run([CLOUDFS_BIN, "list"], capture_output=True, text=True, timeout=2.0)
        lines = [ln for ln in r.stdout.strip().splitlines() if ln.startswith("[")]
        return lines
    except Exception:
        return []


def _server_list() -> list:
    try:
        r = subprocess.run(
            [CLOUDFS_BIN, "server", "list", "--plain"],
            capture_output=True, text=True, timeout=2.0,
        )
        servers = []
        for line in r.stdout.splitlines():
            parts = line.split("|", 2)
            if len(parts) == 3:
                servers.append(tuple(parts))
        return servers
    except Exception:
        return []


class TrayIndicator:
    def __init__(self) -> None:
        self._tmpdir = tempfile.mkdtemp(prefix="cloudfs-")
        self._icon_paths = {}
        for st in STATES:
            path = os.path.join(self._tmpdir, f"{st}.png")
            with open(path, "wb") as f:
                f.write(_render_png(st))
            self._icon_paths[st] = path

        self.state = "idle"
        self.last_ts = 0
        self._last_sig = None
        self._refreshing = False
        self._folders = ()
        self._servers = []
        self._drive_state = "unknown"

        if HAS_AYATANA:
            self._indicator = AppIndicator.Indicator.new(
                "cloudfs", "", AppIndicator.IndicatorCategory.APPLICATION_STATUS
            )
            self._indicator.set_status(AppIndicator.IndicatorStatus.ACTIVE)
            self._indicator.set_icon_full(self._icon_paths["idle"], "cloudfs")
            self._menu = Gtk.Menu()
            # Export a populated root menu. Some AppIndicator hosts cache an
            # initially empty menu and ignore children added by async refresh.
            self._build_menu(self._menu, (), [], "unknown")
            self._indicator.set_menu(self._menu)
        else:
            self._icon = Gtk.StatusIcon()
            self._icon.set_from_pixbuf(_render_pixbuf("idle"))
            self._icon.connect("popup-menu", self._on_popup_menu)
            self._icon.connect("activate", lambda *_: self._sync_now())

        self._update()
        GLib.timeout_add_seconds(POLL_SEC, self._update)

    # ---------- status text ----------

    def _status_text(self) -> str:
        if self.state == "syncing":
            return "Syncing…"
        if self.state == "error":
            return "Error — check log"
        if self.state == "paused":
            return "Paused"
        if self.last_ts:
            return "Idle — last sync " + time.strftime("%H:%M", time.localtime(self.last_ts))
        return "Idle"

    # ---------- menu ----------

    def _build_menu(
        self, menu: Gtk.Menu, folders=None, servers=None, drive_state=None
    ) -> None:
        for child in menu.get_children():
            menu.remove(child)
            child.destroy()

        item = Gtk.MenuItem(label=self._status_text())
        item.set_sensitive(False)
        menu.append(item)

        folders = _cloudfs_list() if folders is None else folders
        if folders:
            sub = Gtk.Menu()
            for ln in folders:
                fi = Gtk.MenuItem(label=ln)
                fi.set_sensitive(False)
                sub.append(fi)
            root = Gtk.MenuItem(label=f"Watched folders ({len(folders)})")
            root.set_submenu(sub)
            menu.append(root)

        servers = _server_list() if servers is None else servers
        if servers:
            server_menu = Gtk.Menu()
            for alias, state, _path in servers:
                actions = Gtk.Menu()

                status_item = Gtk.MenuItem(label=state.capitalize())
                status_item.set_sensitive(False)
                actions.append(status_item)

                if state == "mounted":
                    action = Gtk.MenuItem(label="Open")
                    action.connect("activate", lambda _i, a=alias: self._server_action("open", a))
                    actions.append(action)
                    action = Gtk.MenuItem(label="Unmount")
                    action.connect("activate", lambda _i, a=alias: self._server_action("unmount", a))
                    actions.append(action)
                else:
                    action = Gtk.MenuItem(label="Mount")
                    action.connect("activate", lambda _i, a=alias: self._server_action("mount", a))
                    actions.append(action)

                actions.append(Gtk.SeparatorMenuItem())
                action = Gtk.MenuItem(label="Remove")
                action.connect("activate", lambda _i, a=alias: self._server_action("remove", a))
                actions.append(action)

                server_item = Gtk.MenuItem(label=f"{alias} ({state})")
                server_item.set_submenu(actions)
                server_menu.append(server_item)

            root = Gtk.MenuItem(label=f"Servers ({len(servers)})")
            root.set_submenu(server_menu)
            menu.append(root)

        menu.append(Gtk.SeparatorMenuItem())

        item = Gtk.MenuItem(label="Sync now")
        item.connect("activate", lambda *_: self._sync_now())
        menu.append(item)

        item = Gtk.MenuItem(label="Sync a folder to Drive…")
        item.connect("activate", lambda *_: self._add_folder())
        menu.append(item)

        item = Gtk.MenuItem(label="Add SSH server…")
        item.connect("activate", lambda *_: self._add_server())
        menu.append(item)

        drive_state = drive_state or _unit_state("cloudfs-mount@gdrive.service")
        drive_actions = Gtk.Menu()
        drive_status = Gtk.MenuItem(label=drive_state.capitalize())
        drive_status.set_sensitive(False)
        drive_actions.append(drive_status)
        if drive_state == "mounted":
            action = Gtk.MenuItem(label="Open")
            action.connect("activate", lambda *_: self._run_cloudfs("open"))
            drive_actions.append(action)
            action = Gtk.MenuItem(label="Unmount")
            action.connect("activate", lambda *_: self._run_cloudfs("unmount"))
            drive_actions.append(action)
        else:
            action = Gtk.MenuItem(label="Mount")
            action.connect("activate", lambda *_: self._run_cloudfs("mount"))
            drive_actions.append(action)
        item = Gtk.MenuItem(label=f"Google Drive ({drive_state})")
        item.set_submenu(drive_actions)
        menu.append(item)

        if self.state == "paused":
            item = Gtk.MenuItem(label="Resume syncing")
            item.connect("activate", lambda *_: self._ctl("start"))
        else:
            item = Gtk.MenuItem(label="Pause syncing")
            item.connect("activate", lambda *_: self._ctl("stop"))
        menu.append(item)

        menu.append(Gtk.SeparatorMenuItem())

        item = Gtk.MenuItem(label="View log")
        item.connect("activate", lambda *_: self._open_log())
        menu.append(item)

        item = Gtk.MenuItem(label="View mount logs")
        item.connect("activate", lambda *_: self._open_log(mounts=True))
        menu.append(item)

        item = Gtk.MenuItem(label="Quit tray")
        item.connect("activate", lambda *_: Gtk.main_quit())
        menu.append(item)

        menu.show_all()

    def _on_popup_menu(self, icon, button, activate_time) -> None:
        menu = Gtk.Menu()
        self._build_menu(
            menu, self._folders, self._servers, self._drive_state
        )
        menu.popup(None, None, Gtk.StatusIcon.position_menu, icon, button, activate_time)

    # ---------- actions ----------

    def _ctl(self, action: str) -> None:
        subprocess.Popen(
            ["systemctl", "--user", action, SERVICE],
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
        )
        GLib.timeout_add(600, self._update)

    def _sync_now(self) -> None:
        if self.state == "paused":
            self._ctl("start")
            return
        subprocess.Popen(
            [CLOUDFS_BIN, "sync"],
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
        )
        GLib.timeout_add(600, self._update)

    def _add_folder(self) -> None:
        dialog = Gtk.FileChooserDialog(
            title="cloudfs — choose a folder to sync to Drive",
            action=Gtk.FileChooserAction.SELECT_FOLDER,
        )
        dialog.add_buttons(
            Gtk.STOCK_CANCEL, Gtk.ResponseType.CANCEL,
            "Sync this folder", Gtk.ResponseType.OK,
        )
        response = dialog.run()
        path = dialog.get_filename()
        dialog.destroy()
        if response != Gtk.ResponseType.OK or not path:
            return
        self._run_cloudfs("add", path)

    def _add_server(self) -> None:
        dialog = Gtk.Dialog(title="cloudfs — add SSH server")
        dialog.add_buttons(
            Gtk.STOCK_CANCEL, Gtk.ResponseType.CANCEL,
            "Add server", Gtk.ResponseType.OK,
        )
        box = dialog.get_content_area()
        label = Gtk.Label(label="Host alias from ~/.ssh/config:")
        label.set_xalign(0)
        entry = Gtk.Entry()
        entry.set_placeholder_text("vps")
        box.pack_start(label, False, False, 6)
        box.pack_start(entry, False, False, 6)
        dialog.show_all()
        response = dialog.run()
        alias = entry.get_text().strip()
        dialog.destroy()
        if response != Gtk.ResponseType.OK or not alias:
            return
        self._run_cloudfs("server", "add", alias)

    def _server_action(self, action: str, alias: str) -> None:
        self._run_cloudfs("server", action, alias)

    def _run_cloudfs(self, *args: str) -> None:
        def worker():
            r = subprocess.run([CLOUDFS_BIN, *args], capture_output=True, text=True)
            msg = (r.stdout or r.stderr or "Done.").strip()
            GLib.idle_add(self._notify_result, msg)

        threading.Thread(target=worker, daemon=True).start()

    def _notify_result(self, msg: str) -> bool:
        subprocess.Popen(
            ["notify-send", "--app-name=cloudfs", "cloudfs", msg],
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
        )
        GLib.timeout_add(600, self._update)
        return False

    def _open_log(self, mounts=False) -> None:
        unit = "cloudfs-mount@*" if mounts else "cloudfs"
        script = f"journalctl --user -u '{unit}' -f"
        for cmd in (
            ["gnome-terminal", "--", "bash", "-lc", script],
            ["kgx", "--", "bash", "-lc", script],
            ["x-terminal-emulator", "-e", "bash", "-lc", script],
        ):
            if shutil.which(cmd[0]):
                subprocess.Popen(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
                return

    # ---------- refresh ----------

    def _update(self) -> bool:
        if self._refreshing:
            return True
        self._refreshing = True
        threading.Thread(target=self._collect_snapshot, daemon=True).start()
        return True

    def _collect_snapshot(self) -> None:
        try:
            servers = _server_list()
            drive_state = _unit_state("cloudfs-mount@gdrive.service")
            folders = tuple(_cloudfs_list())
            service_active = _service_active()
            sync_status = _read_status()
            GLib.idle_add(
                self._apply_snapshot,
                folders, servers, drive_state, service_active, sync_status,
            )
        except Exception:
            GLib.idle_add(self._refresh_failed)

    def _refresh_failed(self) -> bool:
        self._refreshing = False
        return False

    def _apply_snapshot(
        self, folders, servers, drive_state, service_active, sync_status
    ) -> bool:
        self._refreshing = False
        self._folders = folders
        self._servers = servers
        self._drive_state = drive_state
        self.state, self.last_ts = _current_state(
            servers, drive_state, service_active, sync_status
        )

        # Only touch the icon/menu when something actually changed —
        # rebuilding the menu while it is open makes it flicker.
        sig = (self.state, self._status_text(), folders, tuple(servers), drive_state)
        if sig == self._last_sig:
            return False
        self._last_sig = sig

        tooltip = "cloudfs: " + self._status_text()
        if HAS_AYATANA:
            self._indicator.set_icon_full(self._icon_paths[self.state], tooltip)
            self._build_menu(self._menu, folders, servers, drive_state)
        else:
            self._icon.set_from_pixbuf(_render_pixbuf(self.state))
            self._icon.set_tooltip_text(tooltip)
        return False


def main() -> int:
    if "DISPLAY" not in os.environ and "WAYLAND_DISPLAY" not in os.environ:
        print("cloudfs-tray: no display found.", file=sys.stderr)
        return 1
    Gtk.init()
    TrayIndicator()
    Gtk.main()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
