#!/bin/bash
# gsync — event-driven folder sync to Google Drive (rclone + inotify).
#
#   gsync add <dir> [drive_path] [--two-way]   watch a folder
#   gsync remove <dir>                         stop watching a folder
#   gsync list                                 show watched folders
#   gsync sync                                 force a sync pass now
#   gsync mount / unmount / open               browse Google Drive at ~/GoogleDrive
#   gsync pause / resume                       stop / start the watcher service
#   gsync status                               service state
#   gsync log                                  follow live log
#   gsync daemon                               run watcher (systemd uses this)
#
# Modes: oneway (default) mirrors local -> Drive (backup semantics).
#        twoway uses rclone bisync; remote changes flow back too.
set -u

CONF_DIR="$HOME/.config/gsync"
CONF="$CONF_DIR/folders.conf"
STATE_DIR="$HOME/.local/state/gsync"
STATUS_FILE="$STATE_DIR/status"
REMOTE="${GSYNC_REMOTE:-gdrive}"
QUIET="${GSYNC_QUIET_SECONDS:-15}"
ROOT="${GSYNC_ROOT:-gsync/$(hostname)}"   # default Drive root for new folders
MOUNT="${GSYNC_MOUNT:-$HOME/GoogleDrive}" # rclone mount location (gsync-mount.service)
ARCHIVE="gsync/.archive/$(hostname)"      # deleted/overwritten files parked here, 30d
ARCHIVE_KEEP_DAYS="${GSYNC_ARCHIVE_DAYS:-30}"

EXCLUDES=(
  --exclude 'node_modules/**'
  --exclude '.cache/**'
  --exclude '__pycache__/**'
  --exclude '.venv/**'
  --exclude 'target/**'
  --exclude 'build/**'
  --exclude '*.tmp'
  --exclude '*.swp'
)

declare -a LOCALS REMOTES MODES
FAILED=0

set_status() { # syncing | idle | error
  mkdir -p "$STATE_DIR"
  printf '%s|%s\n' "$1" "$(date +%s)" > "$STATUS_FILE"
}

load_conf() {
  LOCALS=(); REMOTES=(); MODES=()
  [[ -f "$CONF" ]] || return 0
  while IFS='|' read -r l r m; do
    [[ -z "${l// /}" || "$l" == \#* ]] && continue
    l="${l/#\~/$HOME}"
    if [[ ! -d "$l" ]]; then
      echo "SKIPPED (no such directory): $l"
      continue
    fi
    LOCALS+=("$l"); REMOTES+=("$r"); MODES+=("${m:-oneway}")
  done < "$CONF"
}

sync_one() {
  local l="$1" r="$2" m="$3"
  if [[ "$m" == "twoway" ]]; then
    mkdir -p "$STATE_DIR"
    local marker
    marker="$STATE_DIR/$(printf '%s' "$l" | md5sum | awk '{print $1}').resynced"
    if [[ ! -f "$marker" ]]; then
      echo "bisync (first run, --resync): $l <-> ${REMOTE}:$r"
      rclone bisync "$l" "${REMOTE}:$r" --resync "${EXCLUDES[@]}" && touch "$marker" \
        || { echo "ERROR: initial bisync failed: $l"; FAILED=1; }
    else
      echo "bisync: $l <-> ${REMOTE}:$r"
      rclone bisync "$l" "${REMOTE}:$r" "${EXCLUDES[@]}" \
        || { echo "ERROR: bisync failed: $l  (to force recovery: rm $marker)"; FAILED=1; }
    fi
  else
    echo "sync: $l -> ${REMOTE}:$r"
    # --backup-dir: anything deleted/overwritten is parked under a dated
    # archive folder instead of vanishing (server-side move, cheap).
    rclone sync "$l" "${REMOTE}:$r" "${EXCLUDES[@]}" \
      --backup-dir "${REMOTE}:${ARCHIVE}/$(date +%F)/$r" \
      || { echo "ERROR: sync failed: $l"; FAILED=1; }
  fi
}

cleanup_archive() {
  # Once a day, drop archive date-folders older than ARCHIVE_KEEP_DAYS.
  # Keyed on the folder NAME (= archive date), not file mtimes — rclone's
  # --min-age would look at original file mtimes and delete fresh archives.
  local stamp="$STATE_DIR/last-archive-cleanup" now last=0
  now=$(date +%s)
  [[ -f "$stamp" ]] && last=$(cat "$stamp" 2>/dev/null || echo 0)
  (( now - last < 86400 )) && return 0
  mkdir -p "$STATE_DIR"; echo "$now" > "$stamp"
  local cutoff d
  cutoff=$(date -d "$ARCHIVE_KEEP_DAYS days ago" +%F)
  rclone lsf "${REMOTE}:${ARCHIVE}" --dirs-only 2>/dev/null | while IFS= read -r d; do
    d="${d%/}"
    [[ "$d" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]] || continue
    if [[ "$d" < "$cutoff" ]]; then
      echo "archive cleanup: removing ${ARCHIVE}/$d"
      rclone purge "${REMOTE}:${ARCHIVE}/$d" 2>/dev/null || true
    fi
  done
}

sync_all() {
  FAILED=0
  set_status syncing
  local i
  for i in "${!LOCALS[@]}"; do
    sync_one "${LOCALS[$i]}" "${REMOTES[$i]}" "${MODES[$i]}"
  done
  [[ "$FAILED" -eq 0 ]] && set_status idle || set_status error
}

poll_interval() {
  # twoway folders need polling to pick up remote-side changes
  local i
  for i in "${!MODES[@]}"; do
    [[ "${MODES[$i]}" == "twoway" ]] && { echo 300; return; }
  done
  echo 3600
}

restart_service() {
  if systemctl --user is-active -q gsync 2>/dev/null; then
    systemctl --user restart gsync && echo "Service restarted."
  fi
}

cmd_daemon() {
  load_conf
  if [[ ${#LOCALS[@]} -eq 0 ]]; then
    echo "No folders configured. Add one with: gsync add <dir>"
    set_status idle
    exit 1
  fi
  echo "Initial sync (${#LOCALS[@]} folder(s))..."
  sync_all
  cleanup_archive
  echo "Watching: ${LOCALS[*]}"
  while :; do
    inotifywait -r -q -t "$(poll_interval)" \
      -e create -e modify -e delete -e move -e attrib \
      "${LOCALS[@]}" >/dev/null 2>&1
    sleep "$QUIET"
    load_conf
    sync_all
    cleanup_archive
  done
}

cmd_add() {
  local mode=oneway args=() a
  for a in "$@"; do
    case "$a" in --two-way|--twoway) mode=twoway ;; *) args+=("$a") ;; esac
  done
  if [[ ${#args[@]} -lt 1 ]]; then
    echo "usage: gsync add <local_dir> [drive_path] [--two-way]"
    exit 1
  fi
  local l r
  l="$(realpath -m "${args[0]}")"
  [[ -d "$l" ]] || { echo "No such directory: $l"; exit 1; }

  # Guard 1: paths on the Drive mount are already on Drive — syncing is meaningless.
  if [[ "$l" == "$MOUNT" || "$l" == "$MOUNT"/* ]]; then
    echo "This folder is already on Google Drive (it lives on the ~/GoogleDrive mount)."
    echo "No sync needed — files there are stored in Drive directly."
    exit 1
  fi
  # Guard 2: a path that CONTAINS the mount would recursively pull your whole
  # Drive through the mount (huge traffic, sync loop). Refuse.
  if [[ "$MOUNT" == "$l"/* ]]; then
    echo "Refusing: $l contains the Google Drive mount ($MOUNT)."
    echo "Watching it would recursively download/re-upload your whole Drive."
    echo "Pick specific subfolders instead."
    exit 1
  fi

  r="${args[1]:-$ROOT/$(basename "$l")}"
  mkdir -p "$CONF_DIR"; touch "$CONF"
  local line f fe
  while IFS= read -r line; do
    f="${line%%|*}"
    [[ -z "${f// }" || "$f" == \#* ]] && continue
    fe="${f/#\~/$HOME}"
    [[ "$fe" == "$l" ]] && { echo "Already watched: $l"; exit 1; }
    # Guard 3: nested watches sync the same data twice — confusing and wasteful.
    [[ "$l" == "$fe"/* ]] && { echo "Refusing: $l is inside already-watched $fe."; exit 1; }
    [[ "$fe" == "$l"/* ]] && { echo "Refusing: $l contains already-watched $fe. Remove it first: gsync remove $fe"; exit 1; }
  done < "$CONF"
  echo "${l}|${r}|${mode}" >> "$CONF"
  echo "Added ($mode): $l  ->  ${REMOTE}:$r"
  restart_service
}

cmd_remove() {
  [[ $# -ge 1 ]] || { echo "usage: gsync remove <local_dir>"; exit 1; }
  local l tmp line f fe found=0
  l="$(realpath -m "$1")"
  tmp="$(mktemp)"
  while IFS= read -r line; do
    f="${line%%|*}"; fe="${f/#\~/$HOME}"
    if [[ "$fe" == "$l" ]]; then found=1; continue; fi
    printf '%s\n' "$line"
  done < "$CONF" > "$tmp"
  mv "$tmp" "$CONF"
  if [[ "$found" -eq 1 ]]; then
    echo "Removed: $l (files already on Drive are kept)"
    restart_service
  else
    echo "Not in config: $l"
  fi
}

cmd_list() {
  load_conf
  if [[ ${#LOCALS[@]} -eq 0 ]]; then echo "No folders configured."; return; fi
  local i
  for i in "${!LOCALS[@]}"; do
    printf '%-8s %s  ->  %s:%s\n' "[${MODES[$i]}]" "${LOCALS[$i]}" "$REMOTE" "${REMOTES[$i]}"
  done
}

cmd_sync() {
  load_conf
  [[ ${#LOCALS[@]} -eq 0 ]] && { echo "No folders configured."; exit 1; }
  sync_all
}

cmd_status() {
  local svc="stopped"
  systemctl --user is-active -q gsync 2>/dev/null && svc="running"
  local mnt="not mounted"
  systemctl --user is-active -q gsync-mount 2>/dev/null && mnt="mounted at ~/GoogleDrive"
  local st="-" ts="-"
  if [[ -f "$STATUS_FILE" ]]; then
    IFS='|' read -r st ts < "$STATUS_FILE"
    ts="$(date -d "@$ts" '+%H:%M:%S' 2>/dev/null || echo '-')"
  fi
  echo "service: $svc   last state: $st ($ts)   drive: $mnt"
  echo
  cmd_list
}

cmd_log() { journalctl --user -u gsync -f; }

usage() { sed -n '2,17p' "$0" | sed 's/^# \{0,1\}//'; }

case "${1:-help}" in
  daemon)     cmd_daemon ;;
  add)        shift; cmd_add "$@" ;;
  remove|rm)  shift; cmd_remove "$@" ;;
  list|ls)    cmd_list ;;
  sync)       cmd_sync ;;
  mount)      systemctl --user start gsync-mount && echo "Drive mounted at ~/GoogleDrive" ;;
  unmount)    systemctl --user stop gsync-mount && echo "Unmounted." ;;
  open)       systemctl --user start gsync-mount; xdg-open "$HOME/GoogleDrive" >/dev/null 2>&1 & ;;
  pause)      systemctl --user stop gsync && echo "Paused." ;;
  resume)     systemctl --user start gsync && echo "Resumed." ;;
  status)     cmd_status ;;
  log|logs)   cmd_log ;;
  help|-h|--help|*) usage ;;
esac
