#!/bin/bash
# gsync file-manager context menu script (Nemo "Scripts" mechanism).
# Installed as "Sync to Google Drive" — right-click a folder to start syncing it.
# Right-clicking a file targets the file's parent folder (gsync syncs folders).

notify() {
  command -v notify-send >/dev/null && notify-send --app-name=gsync "gsync" "$1"
}

PATHS="${NAUTILUS_SCRIPT_SELECTED_FILE_PATHS:-${NEMO_SCRIPT_SELECTED_FILE_PATHS:-}}"
[[ -z "$PATHS" ]] && { notify "Nothing selected."; exit 0; }

msgs=()
while IFS= read -r p; do
  [[ -z "$p" ]] && continue
  if [[ -f "$p" ]]; then
    p="$(dirname "$p")"
    msgs+=("(file selected — syncing its folder instead)")
  fi
  out="$("$HOME/.local/bin/gsync" add "$p" 2>&1)"
  msgs+=("$out")
done <<< "$PATHS"

notify "$(printf '%s\n' "${msgs[@]}")"
